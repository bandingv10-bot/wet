<%
const siteTitle = (settings?.siteName || 'DMW STORE').trim() || 'DMW STORE';
const brandName = (settings?.gamePanelName || 'DMW STORE').trim() || 'DMW STORE';
const contact = settings?.contact || {};
const whatsapp = typeof contact.whatsapp === 'string' ? contact.whatsapp.trim() : '';
const telegram = typeof contact.telegram === 'string' ? contact.telegram.trim() : '';
const email = typeof contact.email === 'string' ? contact.email.trim() : '';
const telegramUsername = telegram.replace(/^@/, '');
const telegramLinks = Array.isArray(settings?.telegramLinks) ? settings.telegramLinks : [];
const whatsappLinks = Array.isArray(settings?.whatsappLinks) ? settings.whatsappLinks : [];
const allContactLinks = [
  ...(telegramLinks.length > 0 ? [{...telegramLinks[0], type: 'telegram'}] : []),
  ...(whatsappLinks.length > 0 ? [{...whatsappLinks[0], type: 'whatsapp'}] : []),
  ...(telegramLinks.length > 1 ? [{...telegramLinks[1], type: 'telegram'}] : [])
];
%>
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteTitle %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;800;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.jsdelivr.net/npm/animejs@3.2.1/lib/anime.min.js"></script>
</head>
<body>

<canvas id="particles-canvas"></canvas>

<div class="toast-container" id="toastContainer"></div>

<nav class="nav-main">
<div class="container nav-inner">
<a href="/" class="nav-brand">
<img src="/images/logo.png" alt="<%= brandName %>" onerror="this.style.display='none'">
<span><%= brandName %></span>
</a>
<div class="nav-links" id="navLinks">
<a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Beranda</a>
<% if (user) { %>
<a href="/invoice" class="nav-link <%= currentPath === '/invoice' ? 'active' : '' %>">Invoice</a>
<a href="/history" class="nav-link <%= currentPath === '/history' ? 'active' : '' %>">Riwayat</a>
<a href="/top-buyers" class="nav-link <%= currentPath === '/top-buyers' ? 'active' : '' %>">Top Buyer</a>
<% if (isAdmin) { %>
<a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>">Admin</a>
<% } %>
<% } %>
</div>
<div class="nav-user">
<% if (user) { %>
<span class="nav-username"><%= user.username %></span>
<a href="/logout" class="btn-logout">Logout</a>
<% } else { %>
<a href="/login" class="btn btn-sm btn-primary">Masuk</a>
<a href="/register" class="btn btn-sm btn-secondary">Daftar</a>
<% } %>
</div>
<button class="nav-hamburger" id="navHamburger" aria-label="Menu">
<span class="ham-bar"></span>
<span class="ham-bar"></span>
<span class="ham-bar"></span>
</button>
</div>
<div class="mobile-menu" id="mobileMenu">
<% if (user) { %>
<div class="mobile-menu-user"><%= user.username %></div>
<% } %>
<a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Beranda</a>
<% if (user) { %>
<a href="/invoice" class="nav-link <%= currentPath === '/invoice' ? 'active' : '' %>">Invoice</a>
<a href="/history" class="nav-link <%= currentPath === '/history' ? 'active' : '' %>">Riwayat</a>
<a href="/top-buyers" class="nav-link <%= currentPath === '/top-buyers' ? 'active' : '' %>">Top Buyer</a>
<% if (isAdmin) { %>
<a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>">Admin</a>
<% } %>
<% } %>
<div class="mobile-menu-actions">
<% if (user) { %>
<a href="/logout" class="btn btn-sm btn-danger">Logout</a>
<% } else { %>
<a href="/login" class="btn btn-sm btn-primary">Masuk</a>
<a href="/register" class="btn btn-sm btn-secondary">Daftar</a>
<% } %>
</div>
</div>
</nav>

<main><%- body %></main>

<%- include('partials/footer') %>

<div class="contact-sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="contact-sidebar" id="contactSidebar">
<div class="sidebar-header">
<h3>SALURAN & KONTAK</h3>
<button class="sidebar-close" onclick="closeSidebar()">
<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
</button>
</div>
<div class="sidebar-body">
<div class="sidebar-label">CONTACT & CHANNELS</div>

<% if (allContactLinks.length > 0) { %>
