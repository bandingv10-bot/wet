<td style="text-align:right;">
<form action="/admin/categories/<%= cat %>/delete" method="POST" onsubmit="return confirmDeleteCategory(event, '<%= catLabels[cat] || cat %>')">
<button type="submit" class="btn btn-sm btn-danger">🗑 Hapus</button>
</form>
</td>
</tr>
<% }); %>
<% } else { %>
<tr>
<td colspan="3" style="padding: 32px; text-align: center; color: var(--text-secondary);">
<div style="font-size:32px;margin-bottom:8px;">📂</div>
<div>Belum ada kategori tambahan. Klik <strong>+ Tambah Kategori</strong> untuk mulai.</div>
</td>
</tr>
<% } %>
</tbody>
</table>
</div>

<div style="margin-top:16px;padding:16px;background:rgba(0,212,255,.06);border-radius:8px;display:flex;align-items:flex-start;gap:10px;">
<span style="font-size:16px;margin-top:1px;">ℹ️</span>
<div>
<p style="color:var(--cyan);font-size:13px;margin:0 0 4px;font-weight:600;">Kategori Default (tidak bisa dihapus):</p>
<p style="color:var(--text-secondary);font-size:13px;margin:0;">
<strong style="color:var(--text-primary);">Free Fire</strong> (freefire) &nbsp;·&nbsp;
<strong style="color:var(--text-primary);">Mobile Legends</strong> (mlbb) &nbsp;·&nbsp;
<strong style="color:var(--text-primary);">PUBG</strong> (pubg)
</p>
</div>
</div>
</div>

<script>
function switchTab(tab) {
document.querySelectorAll('.tab-btn').forEach((btn) => btn.classList.remove('active'));
document.querySelectorAll('.tab-content').forEach((content) => {
content.classList.remove('active');
content.style.opacity = '';
});
document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
const target = document.getElementById(`tab-${tab}`);
target.classList.add('active');
anime({
targets: target,
opacity: [0, 1],
translateY: [12, 0],
duration: 380,
easing: 'easeOutExpo'
});
const rows = target.querySelectorAll('.admin-table tbody tr, .mobile-product-card');
if (rows.length) {
anime({
targets: rows,
translateX: [-18, 0],
opacity: [0, 1],
delay: anime.stagger(35, { start: 60 }),
duration: 380,
easing: 'easeOutExpo'
});
}
if (window.innerWidth <= 768) {
document.getElementById('tabNav').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
}

function toggleForm(id) {
const form = document.getElementById(id + 'Form');
if (!form) return;
if (form.classList.contains('show')) {
anime({
targets: form,
opacity: [1, 0],
translateY: [0, -8],
duration: 220,
easing: 'easeInQuad',
complete: () => form.classList.remove('show')
});
} else {
form.classList.add('show');
anime({
targets: form,
opacity: [0, 1],
translateY: [-12, 0],
duration: 400,
easing: 'easeOutExpo'
});
anime({
targets: form.querySelectorAll('.input-group, .pricing-keys-layout, .admin-form-grid'),
translateY: [10, 0],
opacity: [0, 1],
delay: anime.stagger(50, { start: 80 }),
duration: 380,
easing: 'easeOutExpo'
});
}
}

function toggleEditForm(id) {
const form = document.getElementById(id);
if (!form) return;
const isVisible = window.getComputedStyle(form).display !== 'none';
document.querySelectorAll('.product-edit-panel').forEach((panel) => {
panel.style.display = 'none';
panel.style.opacity = '';
});
if (!isVisible) {
form.style.display = form.dataset.display || (form.tagName === 'TR' ? 'table-row' : 'block');
anime({
targets: form,
opacity: [0, 1],
translateY: [-10, 0],
duration: 380,
easing: 'easeOutExpo'
});
anime({
targets: form.querySelectorAll('.input-group, .pricing-keys-layout, .admin-form-grid'),
translateY: [8, 0],
opacity: [0, 1],
delay: anime.stagger(45, { start: 60 }),
duration: 350,
easing: 'easeOutExpo'
});
form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
}

document.addEventListener('DOMContentLoaded', function() {
anime({
targets: '.admin-title',
translateX: [-30, 0],
opacity: [0, 1],
duration: 700,
easing: 'easeOutExpo'
});
anime({
targets: '.stat-card',
translateY: [-28, 0],
opacity: [0, 1],
delay: anime.stagger(80),
duration: 600,
easing: 'easeOutBack'
});
anime({
targets: '.tab-btn',
translateY: [-10, 0],
opacity: [0, 1],
delay: anime.stagger(50, { start: 300 }),
duration: 450,
easing: 'easeOutExpo'
});
anime({
targets: '#tab-products.active .admin-toolbar',
translateX: [-20, 0],
opacity: [0, 1],
duration: 500,
delay: 400,
easing: 'easeOutExpo'
});
anime({
targets: '#tab-products.active .admin-table tbody tr, #tab-products.active .mobile-product-card',
translateX: [-16, 0],
opacity: [0, 1],
delay: anime.stagger(40, { start: 500 }),
duration: 380,
easing: 'easeOutExpo'
});

var marqueeInput = document.querySelector('textarea[name="marqueeText"]');
var marqueePreviewText = document.getElementById('marqueePreviewText');
if (marqueeInput && marqueePreviewText) {
marqueeInput.addEventListener('input', function() {
marqueePreviewText.textContent = this.value || 'Teks marquee akan tampil di sini...';
});
}

function filterTransactions(status, btn) {
  document.querySelectorAll('.tx-filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  const rows = document.querySelectorAll('#transactionsTableBody tr[data-tx-status]');
  rows.forEach(row => {
    const show = status === 'all' || row.dataset.txStatus === status;
    row.style.display = show ? '' : 'none';
  });
}

function confirmDeleteCategory(e, name) {
  if (!confirm('Yakin hapus kategori "' + name + '"?\n\nProduk dengan kategori ini tidak akan ikut terhapus, tapi kategorinya tidak akan muncul di list.')) {
    e.preventDefault();
    return false;
  }
  return true;
}

// Auto-switch tab berdasarkan URL param ?tab=xxx
(function() {
  var params = new URLSearchParams(window.location.search);
  var tab = params.get('tab');
  if (tab) {
    setTimeout(function() {
      switchTab(tab);
      // Auto buka form jika param openForm=addCategory
      var openForm = params.get('openForm');
      if (openForm) toggleForm(openForm);
    }, 100);
  }
})();

// Auto-hide success alert setelah 4 detik
var successAlert = document.getElementById('categorySuccessAlert');
if (successAlert) {
  setTimeout(function() {
    anime({ targets: successAlert, opacity: [1, 0], translateY: [0, -8], duration: 350, easing: 'easeInQuad', complete: function() { successAlert.remove(); } });
  }, 4000);
}

document.querySelectorAll('.tab-btn').forEach(function(btn) {
btn.addEventListener('mouseenter', function() {
if (!this.classList.contains('active')) {
anime({ targets: this, scale: [1, 1.05], duration: 180, easing: 'easeOutQuad' });
}
});
btn.addEventListener('mouseleave', function() {
anime({ targets: this, scale: [1.05, 1], duration: 180, easing: 'easeOutQuad' });
});
});

document.querySelectorAll('.btn-primary, .btn-danger').forEach(function(btn) {
btn.addEventListener('click', function() {
anime({
targets: this,
scale: [1, 0.93, 1],
duration: 260,
easing: 'easeOutElastic(1, .5)'
});
});
});
});

function editBanner(bannerId) {
var banners = <%- JSON.stringify(settings.banners || []) %>;
var banner = banners.find(function(b) { return b.id === bannerId; });
if (banner) {
document.getElementById('bannerEditId').value = banner.id;
document.getElementById('bannerEditTitle').value = banner.title || '';
document.getElementById('bannerEditSubtitle').value = banner.subtitle || '';
document.getElementById('bannerEditImage').value = banner.image || '';
document.getElementById('bannerEditActive').value = banner.active ? 'true' : 'false';
toggleForm('addBanner');
}
}

function addFooterSection() {
var editor = document.getElementById('footerLinksEditor');
var newSection = document.createElement('div');
newSection.className = 'footer-section-block';
newSection.style.cssText = 'background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:16px;';
newSection.innerHTML = '<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;"><input type="text" name="footerSectionName" value="" placeholder="Nama Section (contoh: INFORMASI)" style="flex:1;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:14px;font-weight:600;"><button type="button" class="btn btn-sm btn-danger" onclick="removeFooterSection(this)" style="padding:10px 12px;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div><div class="footer-links-list-editor" style="display:flex;flex-direction:column;gap:8px;"></div><button type="button" class="btn btn-sm btn-secondary" onclick="addFooterLinkRow(this)" style="margin-top:10px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Tambah Link</button>';
editor.appendChild(newSection);
anime({ targets: newSection, opacity: [0, 1], translateY: [20, 0], duration: 400, easing: 'easeOutExpo' });
}

function removeFooterSection(btn) {
var section = btn.closest('.footer-section-block');
if (section) {
anime({ targets: section, opacity: [1, 0], translateY: [0, -10], duration: 250, easing: 'easeInQuad', complete: function() { section.remove(); } });
}
}

function addFooterLinkRow(btn) {
var sectionBlock = btn.closest('.footer-section-block');
var linksList = sectionBlock.querySelector('.footer-links-list-editor');
if (linksList) {
var newRow = document.createElement('div');
newRow.className = 'footer-link-editor-row';
newRow.style.cssText = 'display:flex;gap:10px;align-items:center;';
newRow.innerHTML = '<input type="text" name="footerLinkTitle" value="" placeholder="Judul Link" style="flex:1;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:14px;"><input type="text" name="footerLinkUrl" value="" placeholder="URL (contoh: /faq)" style="flex:1;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:14px;"><button type="button" class="btn btn-sm btn-danger" onclick="removeFooterLinkRow(this)" style="padding:10px 12px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>';
linksList.appendChild(newRow);
anime({
targets: newRow,
opacity: [0, 1],
translateY: [10, 0],
duration: 300,
easing: 'easeOutExpo'
});
}
}

function removeFooterLinkRow(btn) {
var row = btn.closest('.footer-link-editor-row');
if (row) {
anime({
targets: row,
opacity: [1, 0],
translateX: [0, -20],
duration: 250,
easing: 'easeInQuad',
complete: function() { row.remove(); }
});
}
}

document.getElementById('footerLinksForm').addEventListener('submit', function(e) {
var sections = [];
var sectionBlocks = document.querySelectorAll('#footerLinksEditor > .footer-section-block');
sectionBlocks.forEach(function(block) {
var sectionName = block.querySelector('input[name="footerSectionName"]').value.trim();
if (sectionName) {
var links = [];
var linkRows = block.querySelectorAll('.footer-link-editor-row');
linkRows.forEach(function(row) {
var title = row.querySelector('input[name="footerLinkTitle"]').value.trim();
var url = row.querySelector('input[name="footerLinkUrl"]').value.trim();
if (title && url) {
links.push({ id: links.length + 1, title: title, url: url });
}
});
sections.push({ section: sectionName, links: links });
}
});
document.getElementById('footerLinksData').value = JSON.stringify(sections);
});

function toggleNewCategoryInput() {
  var select = document.getElementById('newProductCategory');
  var input = document.getElementById('newCategoryInput');
  if (select.value === '__new__') {
    input.style.display = 'block';
    input.required = true;
    select.required = false;
  } else {
    input.style.display = 'none';
    input.required = false;
    select.required = true;
  }
}

function addPricingRow() {
  var container = document.getElementById('newPricingRows');
  var newRow = document.createElement('div');
  newRow.className = 'pricing-editor-row';
  newRow.innerHTML = '<input type="number" name="pricingDays" min="1" value="" placeholder="1"><input type="number" name="pricingPrices" min="0" value="" placeholder="15000"><button type="button" class="btn-remove-row" onclick="removePricingRow(this)">×</button>';
  container.appendChild(newRow);
  anime({ targets: newRow, opacity: [0, 1], translateY: [-10, 0], duration: 300, easing: 'easeOutExpo' });
}

function removePricingRow(btn) {
  var row = btn.closest('.pricing-editor-row');
  if (row) {
    var container = document.getElementById('newPricingRows');
    if (container.querySelectorAll('.pricing-editor-row').length > 3) {
      anime({ targets: row, opacity: [1, 0], translateX: [0, -20], duration: 250, easing: 'easeInQuad', complete: function() { row.remove(); } });
    }
  }
}
</script>