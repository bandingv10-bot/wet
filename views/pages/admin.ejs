<td><span class="badge badge-active">Active</span></td>
<td style="text-align:right;">
<form action="/admin/users/<%= u.username %>/delete" method="POST" onsubmit="return confirm('Hapus user &quot;<%= u.username %>&quot;?\nSemua data transaksi user ini akan tetap tersimpan.')">
