<div class="mobile-pricing-list">
<% p.pricingOptions.forEach((option) => { %>
<div class="mobile-pricing-row">
<span><%= option.days %> Hari</span>
<strong><%= formatPriceShort(option.price) %></strong>
</div>
<% }); %>
</div>
<% if (p.keys && p.keys.length > 0) { %>
<div class="mobile-keys-list">
<div class="mobile-keys-header">Keys (<%= p.keys.length %>)</div>
<div class="mobile-keys-content"><%= p.keys.join('\n') %></div>
</div>
<% } %>
<div class="admin-action-row">
<button type="button" onclick="toggleEditForm('edit-mobile-<%= p.id %>')" class="btn btn-sm btn-secondary">Edit</button>
<form action="/admin/products/<%= p.id %>/toggle" method="POST">
<button type="submit" class="btn btn-sm <%= p.status === 'active' ? 'btn-secondary' : 'btn-primary' %>"><%= p.status === 'active' ? 'Nonaktif' : 'Aktifkan' %></button>
</form>
<form action="/admin/products/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Yakin hapus?')">
<button type="submit" class="btn btn-sm btn-danger">Hapus</button>
</form>
</div>
<div id="edit-mobile-<%= p.id %>" class="product-edit-panel mobile-edit-panel" data-display="block" style="display:none;">
<form action="/admin/products/<%= p.id %>" method="POST" enctype="multipart/form-data">
<div class="admin-form-grid">
<div class="input-group">
