<%
const categoryLabels = Object.assign({
  freefire: 'Free Fire',
  mlbb: 'Mobile Legends',
  pubg: 'PUBG'
}, settings.categoryLabels || {});
const formatPriceShort = (value) => `Rp ${(Number(value || 0) / 1000).toFixed(0)}K`;
const buildPricingRows = (product) => {
  const source = Array.isArray(product?.pricingOptions) && product.pricingOptions.length > 0
    ? product.pricingOptions.map((option) => ({ days: option.days, price: option.price }))
    : [
        { days: 1, price: product?.price1day || 0 },
        { days: 3, price: product?.price3day || 0 },
        { days: 7, price: product?.price7day || 0 }
      ];
  return source;
};
const newProductPricingRows = [
  { days: 1, price: 15000 },
  { days: 3, price: 30000 },
  { days: 7, price: 60000 }
];
%>
<div class="admin-page">
<h1 class="admin-title">Admin Dashboard</h1>
<% if (typeof error !== 'undefined' && error) { %>
<div class="alert-error"><%= error %></div>
<% } %>

<div class="admin-stats">
<div class="stat-card">
<p class="stat-value"><%= products.length %></p>
<p class="stat-label">Total Produk</p>
</div>
<div class="stat-card">
<p class="stat-value" style="color: #22c55e;"><%= users.length %></p>
<p class="stat-label">Total User</p>
</div>
<div class="stat-card">
<p class="stat-value" style="color: #f59e0b;"><%= transactions.length %></p>
<p class="stat-label">Total Transaksi</p>
</div>
<div class="stat-card">
<p class="stat-value" style="color: #a855f7;">Rp <%= (transactions.filter((t) => t.status === 'completed').reduce((sum, t) => sum + t.price, 0) / 1000).toFixed(0) %>K</p>
<p class="stat-label">Revenue</p>
</div>
</div>

<div class="tab-nav" id="tabNav">
<button class="tab-btn active" data-tab="products" onclick="switchTab('products')">Produk</button>
<button class="tab-btn" data-tab="transactions" onclick="switchTab('transactions')">Transaksi</button>
<button class="tab-btn" data-tab="broadcast" onclick="switchTab('broadcast')">Broadcast</button>
<button class="tab-btn" data-tab="settings" onclick="switchTab('settings')">Settings</button>
<button class="tab-btn" data-tab="vouchers" onclick="switchTab('vouchers')">Voucher</button>
<button class="tab-btn" data-tab="banners" onclick="switchTab('banners')">Banner</button>
<button class="tab-btn" data-tab="categories" onclick="switchTab('categories')">Kategori</button>
<button class="tab-btn" data-tab="users" onclick="switchTab('users')">User</button>
</div>

<div id="tab-products" class="tab-content active">
<div class="admin-toolbar">
<button class="btn btn-primary" onclick="toggleForm('addProduct')">+ Tambah Produk</button>
</div>

<div id="addProductForm" class="edit-form">
<h3 style="font-size: 20px; font-weight: 700; margin-bottom: 24px;">Tambah Produk Baru</h3>
<form action="/admin/products" method="POST" enctype="multipart/form-data">
<div class="admin-form-grid">
<div class="input-group">
<label>Nama Produk</label>
<input type="text" name="name" required placeholder="Contoh: Drip Client Non Root">
</div>
<div class="input-group">
<label>Kategori</label>
<select name="category" id="newProductCategory" required onchange="toggleNewCategoryInput()">
<% const defaultCats = ['freefire', 'mlbb', 'pubg']; %>
<% defaultCats.forEach((cat) => { %>
<option value="<%= cat %>"><%= categoryLabels[cat] || cat %></option>
<% }); %>
<% (settings.categories || []).forEach((cat) => { %>
<option value="<%= cat %>"><%= (settings.categoryLabels || {})[cat] || (cat.charAt(0).toUpperCase() + cat.slice(1)) %></option>
<% }); %>
<option value="__new__">+ Tambah Kategori Baru</option>
</select>
<input type="text" id="newCategoryInput" name="newCategory" placeholder="Nama kategori baru (slug)" style="display:none; margin-top:8px;">
</div>
<div class="input-group">
<label>Status</label>
<select name="status">
<option value="active">Active</option>
<option value="inactive">Inactive</option>
</select>
</div>
</div>
<div class="input-group">
<label>Image Produk</label>
<input type="file" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp">
<p class="admin-form-note">Format: JPEG, PNG, GIF, WebP. Maksimal 5MB.</p>
</div>
<div class="pricing-keys-layout">
<div class="input-group" style="margin-bottom:0;">
<label>Tabel Durasi & Harga</label>
<div class="pricing-editor">
<div class="pricing-editor-head">
<span>Days</span>
<span>Price</span>
<span></span>
</div>
<div id="newPricingRows">
<% newProductPricingRows.forEach((row, idx) => { %>
<div class="pricing-editor-row" data-row-id="<%= idx %>">
<input type="number" name="pricingDays" min="1" value="<%= row.days %>" placeholder="1">
<input type="number" name="pricingPrices" min="0" value="<%= row.price %>" placeholder="15000">
<button type="button" class="btn-remove-row" onclick="removePricingRow(this)" <%= idx < 3 ? 'style="visibility:hidden;"' : '' %>>×</button>
</div>
<% }); %>
</div>
<button type="button" class="btn btn-sm btn-secondary" onclick="addPricingRow()" style="margin-top:8px;">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
Tambah Baris
</button>
</div>
<div class="input-group" style="margin-bottom:0;">
<label>Keys</label>
<textarea name="keys" placeholder="KEY-001&#10;KEY-002&#10;KEY-003" style="font-family: monospace; min-height: 178px; resize: vertical;"></textarea>
</div>
</div>
<div class="input-group">
<label>Deskripsi</label>
<textarea name="description" placeholder="Deskripsi produk..."></textarea>
</div>
<div style="display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;">
<button type="submit" class="btn btn-primary">Simpan</button>
<button type="button" class="btn btn-secondary" onclick="toggleForm('addProduct')">Batal</button>
</div>
</form>
</div>

<div class="admin-table-wrapper desktop-only">
<table class="admin-table admin-product-table">
<thead>
<tr>
<th>Produk</th>
<th>Kategori</th>
<th>Durasi, Harga & Keys</th>
<th>Status</th>
<th style="text-align:right;">Aksi</th>
</tr>
</thead>
<tbody>
<% products.forEach((p) => { const editRows = buildPricingRows(p); %>
<tr>
<td>
<div class="admin-product-head">
<img src="<%= p.image %>" alt="<%= p.name %>" class="admin-product-thumb" onerror="this.src='/images/placeholder.jpg'">
<div>
<p class="admin-product-name"><%= p.name %></p>
<p class="admin-product-desc"><%= p.description.substring(0, 80) %></p>
</div>
</div>
</td>
<td><span class="badge badge-active"><%= (categoryLabels[p.category] || p.category).toUpperCase() %></span></td>
<td>
<div class="admin-pricing-preview">
<% p.pricingOptions.forEach((option) => { %>
<div class="admin-pricing-item">
<span><%= option.days %> Hari</span>
<strong><%= formatPriceShort(option.price) %></strong>
</div>
<% }); %>
</div>
<% if (p.keys && p.keys.length > 0) { %>
<div class="admin-keys-preview">
<div class="admin-keys-header">Keys (<%= p.keys.length %>)</div>
<div class="admin-keys-list"><%= p.keys.join('\n') %></div>
</div>
<% } %>
</td>
<td><span class="badge <%= p.status === 'active' ? 'badge-active' : 'badge-inactive' %>"><%= p.status %></span></td>
<td style="text-align:right;">
<div class="admin-action-row admin-action-row-end">
<button type="button" onclick="toggleEditForm('edit-desktop-<%= p.id %>')" class="btn btn-sm btn-secondary">Edit</button>
<form action="/admin/products/<%= p.id %>/toggle" method="POST">
<button type="submit" class="btn btn-sm <%= p.status === 'active' ? 'btn-secondary' : 'btn-primary' %>"><%= p.status === 'active' ? 'Nonaktif' : 'Aktifkan' %></button>
</form>
<form action="/admin/products/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Yakin hapus?')">
<button type="submit" class="btn btn-sm btn-danger">Hapus</button>
</form>
</div>
</td>
</tr>
<tr id="edit-desktop-<%= p.id %>" class="product-edit-panel" data-display="table-row" style="display:none;">
<td colspan="6" style="padding: 16px; background: rgba(250,204,21,.06);">
<form action="/admin/products/<%= p.id %>" method="POST" enctype="multipart/form-data">
<div class="admin-form-grid">
<div class="input-group">
<label>Nama Produk</label>
<input type="text" name="name" value="<%= p.name %>" required>
</div>
<div class="input-group">
<label>Kategori</label>
<select name="category" required>
<option value="freefire" <%= p.category === 'freefire' ? 'selected' : '' %>>Free Fire</option>
<option value="mlbb" <%= p.category === 'mlbb' ? 'selected' : '' %>>Mobile Legends</option>
<option value="pubg" <%= p.category === 'pubg' ? 'selected' : '' %>>PUBG</option>
<% (settings.categories || []).forEach((cat) => { %>
<option value="<%= cat %>" <%= p.category === cat ? 'selected' : '' %>><%= (settings.categoryLabels || {})[cat] || (cat.charAt(0).toUpperCase() + cat.slice(1)) %></option>
<% }); %>
</select>
</div>
<div class="input-group">
<label>Status</label>
<select name="status">
<option value="active" <%= p.status === 'active' ? 'selected' : '' %>>Active</option>
<option value="inactive" <%= p.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
</select>
</div>
</div>
<div class="input-group">
<label>Image Produk</label>
<div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
<img src="<%= p.image %>" alt="<%= p.name %>" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);">
<div>
<input type="file" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp">
<p class="admin-form-note">Kosongkan jika tidak ingin mengubah image.</p>
</div>
</div>
</div>
<div class="pricing-keys-layout">
<div class="input-group" style="margin-bottom:0;">
<label>Tabel Durasi & Harga</label>
<div class="pricing-editor">
<div class="pricing-editor-head">
<span>Days</span>
<span>Price</span>
</div>
<% editRows.forEach((row) => { %>
<div class="pricing-editor-row">
<input type="number" name="pricingDays" min="1" value="<%= row.days %>" placeholder="1">
<input type="number" name="pricingPrices" min="0" value="<%= row.price %>" placeholder="15000">
</div>
<% }); %>
</div>
</div>
<div class="input-group" style="margin-bottom:0;">
<label>Keys</label>
<textarea name="keys" style="font-family: monospace; min-height: 178px; resize: vertical;"><%= p.keys ? p.keys.join('\n') : '' %></textarea>
</div>
</div>
<div class="input-group">
<label>Deskripsi</label>
<textarea name="description"><%= p.description %></textarea>
</div>
<div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
<button type="submit" class="btn btn-primary">Simpan</button>
<button type="button" class="btn btn-secondary" onclick="toggleEditForm('edit-desktop-<%= p.id %>')">Batal</button>
</div>
</form>
</td>
</tr>
<% }); %>
</tbody>
</table>
</div>

<div class="mobile-only mobile-product-list">
<% products.forEach((p) => { const editRows = buildPricingRows(p); %>
<div class="mobile-product-card">
<div class="admin-product-head">
<img src="<%= p.image %>" alt="<%= p.name %>" class="admin-product-thumb" onerror="this.src='/images/placeholder.jpg'">
<div>
<p class="admin-product-name"><%= p.name %></p>
<p class="admin-product-desc"><%= p.description.substring(0, 90) %></p>
</div>
</div>
<div class="mobile-product-badges">
