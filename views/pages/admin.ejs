<% }); %>
<% } else { %>
<div class="footer-section-template" style="display:none;">
<div class="footer-section-block" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:16px;">
<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
<input type="text" name="footerSectionName" value="" placeholder="Nama Section (contoh: INFORMASI)" style="flex:1;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:14px;font-weight:600;">
<button type="button" class="btn btn-sm btn-danger" onclick="removeFooterSection(this)" style="padding:10px 12px;flex-shrink:0;">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
</button>
</div>
<div class="footer-links-list-editor" style="display:flex;flex-direction:column;gap:8px;"></div>
<button type="button" class="btn btn-sm btn-secondary" onclick="addFooterLinkRow(this)" style="margin-top:10px;">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
Tambah Link
</button>
</div>
</div>
<% } %>
</div>
<div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;">
<button type="button" class="btn btn-secondary" onclick="addFooterSection()">
<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
Tambah Section
</button>
<button type="submit" class="btn btn-primary">Simpan Footer Links</button>
