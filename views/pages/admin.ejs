<form action="/admin/settings" method="POST">
<input type="hidden" name="siteName" value="<%= settings.siteName || 'DMW STORE' %>">
<input type="hidden" name="gamePanelName" value="<%= settings.gamePanelName || 'DMW STORE' %>">
