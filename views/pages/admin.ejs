<label>Diskon (%)</label>
<input type="number" name="discountPercent" required placeholder="20" min="1" max="100">
</div>
<div class="input-group">
<label>Minimum Pembelian (Rp)</label>
<input type="number" name="minPurchase" required placeholder="50000" min="0">
</div>
<div class="input-group">
<label>Status</label>
<select name="active">
<option value="true">Active</option>
<option value="false">Inactive</option>
</select>
</div>
</div>
<div style="display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;">
<button type="submit" class="btn btn-primary">Simpan</button>
<button type="button" class="btn btn-secondary" onclick="toggleForm('addVoucher')">Batal</button>
</div>
</form>
</div>
<div class="admin-table-wrapper">
