<thead>
<tr>
<th>Kode</th>
<th>Diskon</th>
<th>Min. Pembelian</th>
<th>Status</th>
<th style="text-align:right;">Aksi</th>
</tr>
</thead>
<tbody>
<% if (settings.vouchers && settings.vouchers.length > 0) { %>
<% settings.vouchers.forEach((v) => { %>
<tr>
<td><code style="background: rgba(250,204,21,.06); padding: 6px 10px; border-radius: 6px; font-size: 13px; font-weight: 600;"><%= v.code %></code></td>
<td style="font-weight: 600; color: #22c55e;"><%= v.discountPercent %>%</td>
<td><%= formatPriceShort(v.minPurchase) %></td>
<td><span class="badge <%= v.active ? 'badge-active' : 'badge-inactive' %>"><%= v.active ? 'Active' : 'Inactive' %></span></td>
<td style="text-align:right;">
<form action="/admin/vouchers/<%= v.code %>/delete" method="POST" onsubmit="return confirm('Yakin hapus voucher ini?')">
<button type="submit" class="btn btn-sm btn-danger">Hapus</button>
</form>
</td>
</tr>
<% }); %>
<% } else { %>
<tr>
<td colspan="5" style="padding: 32px; text-align: center; color: var(--text-secondary);">Belum ada voucher</td>
</tr>
<% } %>
</tbody>
</table>
</div>
</div>

