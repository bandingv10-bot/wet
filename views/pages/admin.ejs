<div id="addVoucherForm" class="edit-form">
<h3 style="font-size: 20px; font-weight: 700; margin-bottom: 24px;">Tambah / Edit Voucher</h3>
<form action="/admin/vouchers" method="POST">
<div class="admin-form-grid">
<div class="input-group">
<label>Kode Voucher</label>
<input type="text" name="code" required placeholder="Contoh: DISKON20" style="text-transform: uppercase;">
</div>
