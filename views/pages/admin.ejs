</select>
</div>
</div>
<div class="input-group">
<label>Image Produk</label>
<div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
<img src="<%= p.image %>" alt="<%= p.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1);">
<input type="file" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp">
</div>
</div>
