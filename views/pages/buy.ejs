<%
const pricingOptions = Array.isArray(product.pricingOptions) && product.pricingOptions.length > 0
  ? product.pricingOptions
  : [
      { days: 1, price: product.price1day || 0 },
      { days: 3, price: product.price3day || 0 },
      { days: 7, price: product.price7day || 0 }
    ];
const defaultOption = pricingOptions[0] || { days: 1, price: 0 };
%>
<div class="container buy-page">
<div style="margin-bottom: 32px;">
<a href="/" style="display: inline-flex; align-items: center; gap: 8px; color: var(--text-secondary); transition: color .3s;">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
<line x1="19" y1="12" x2="5" y2="12"/>
<polyline points="12 19 5 12 12 5"/>
</svg>
Kembali
</a>
</div>
<div class="card buy-card">
<div class="buy-card-hero">
<div class="buy-card-hero-bg" style="background-image:url('<%= product.image %>')"></div>
<img class="buy-card-hero-img" src="<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/images/placeholder.jpg'">
<span class="badge badge-active"><%= product.category.toUpperCase() %></span>
</div>
<div class="buy-card-content">
<h1 class="buy-title"><%= product.name %></h1>
<p class="buy-description"><%= product.description %></p>
<div style="margin-bottom: 32px;">
<h3 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">Pilih Durasi:</h3>
<div class="duration-options">
<% pricingOptions.forEach((option, index) => { %>
<label style="cursor: pointer;">
<input type="radio" name="duration" value="<%= option.days %>" <%= index === 0 ? 'checked' : '' %> style="display: none;">
<div class="duration-card <%= index === 0 ? 'selected' : '' %>" data-value="<%= option.days %>">
<p class="price">Rp <%= (option.price / 1000).toFixed(0) %>K</p>
<p class="period"><%= option.days %> Hari</p>
</div>
</label>
<% }); %>
</div>
</div>
<div class="voucher-section">
<h3>Kode Voucher (Opsional):</h3>
<div class="voucher-form">
<input type="text" id="voucherInput" placeholder="Masukkan kode voucher" style="text-transform: uppercase;">
<button type="button" onclick="applyVoucher()" class="btn btn-secondary">Gunakan</button>
</div>
<p id="voucherMessage" style="margin-top: 12px; font-size: 14px; display: none;"></p>
</div>
<div class="order-summary">
<div class="row">
<span>Subtotal</span>
<span id="subtotalPrice">Rp <%= (defaultOption.price / 1000).toFixed(0) %>K</span>
</div>
<div class="row" id="discountRow" style="display: none;">
<span class="discount">Diskon</span>
<span class="discount" id="discountPrice">-Rp 0</span>
</div>
<div class="row">
<span>Metode Pembayaran</span>
<span id="paymentMethod">QRIS</span>
</div>
<div class="row">
<span>Total</span>
<span id="totalPrice" style="color: var(--yellow);">Rp <%= (defaultOption.price / 1000).toFixed(0) %>K</span>
</div>
</div>
<form action="/buy/<%= product.id %>" method="POST" id="buyForm">
<input type="hidden" name="duration" id="durationInput" value="<%= defaultOption.days %>">
<input type="hidden" name="voucher" id="voucherHidden">
<input type="hidden" name="paymentMethod" id="paymentMethodInput" value="qris">
<div style="margin-bottom: 24px;">
<label style="display: block; margin-bottom: 12px; font-weight: 500; color: var(--text-secondary);">Metode Pembayaran:</label>
<div class="payment-methods">
<div class="payment-method-btn selected" data-method="qris" onclick="selectPayment(this)" style="border: 2px solid var(--yellow); background: rgba(250,204,21,.08);">
<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="2" style="margin-bottom: 8px;">
<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
<line x1="3" y1="9" x2="21" y2="9"/>
<line x1="9" y1="21" x2="9" y2="9"/>
</svg>
<p style="font-weight: 600; color: var(--text-primary);">QRIS</p>
<p style="font-size: 12px; color: var(--text-secondary);">Pembayaran via QRIS</p>
</div>
</div>
</div>
<button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">Beli Sekarang</button>
</form>
</div>
</div>
</div>
<script>
const pricingOptions = <%- JSON.stringify(pricingOptions) %>;
const prices = Object.fromEntries(pricingOptions.map((option) => [String(option.days), option.price]));
let selectedDuration = '<%= defaultOption.days %>';
let currentDiscount = 0;
let selectedPayment = 'qris';

const durationCards = document.querySelectorAll('.duration-card');
durationCards.forEach((card) => {
card.addEventListener('click', function() {
const radio = this.parentElement.querySelector('input[type="radio"]');
radio.checked = true;
selectedDuration = radio.value;
updateDurationCards();
updatePrice();
});
});

function updateDurationCards() {
durationCards.forEach((card) => {
if (card.dataset.value === selectedDuration) {
card.classList.add('selected');
} else {
card.classList.remove('selected');
}
});
}

function selectPayment(el) {
document.querySelectorAll('.payment-method-btn').forEach((btn) => {
btn.style.borderColor = 'var(--border)';
btn.style.background = 'rgba(250,204,21,.05)';
});
el.style.borderColor = 'var(--yellow)';
el.style.background = 'rgba(250,204,21,.1)';
selectedPayment = el.dataset.method;
document.getElementById('paymentMethodInput').value = selectedPayment;
document.getElementById('paymentMethod').textContent = selectedPayment === 'qris' ? 'QRIS' : 'Manual / Langsung';
}

function updatePrice() {
const price = prices[selectedDuration] || 0;
const discount = currentDiscount;
const total = price - discount;
document.getElementById('subtotalPrice').textContent = 'Rp ' + (price / 1000).toFixed(0) + 'K';
document.getElementById('totalPrice').textContent = 'Rp ' + (total / 1000).toFixed(0) + 'K';
if (discount > 0) {
document.getElementById('discountRow').style.display = 'flex';
document.getElementById('discountPrice').textContent = '-Rp ' + (discount / 1000).toFixed(0) + 'K';
} else {
document.getElementById('discountRow').style.display = 'none';
}
document.getElementById('durationInput').value = selectedDuration;
}

document.querySelectorAll('input[name="duration"]').forEach((radio) => {
radio.addEventListener('change', function() {
selectedDuration = this.value;
updateDurationCards();
updatePrice();
});
});

function applyVoucher() {
const code = document.getElementById('voucherInput').value.toUpperCase();
const message = document.getElementById('voucherMessage');
if (!code) {
message.textContent = 'Masukkan kode voucher';
message.style.color = '#dc2626';
message.style.display = 'block';
return;
}
fetch('/api/vouchers/validate/' + code)
.then((res) => res.json())
.then((data) => {
if (data.valid) {
currentDiscount = Math.round((prices[selectedDuration] || 0) * (data.discountPercent / 100));
message.textContent = 'Voucher aktif! Diskon ' + data.discountPercent + '%';
message.style.color = '#16a34a';
updatePrice();
} else {
currentDiscount = 0;
message.textContent = 'Voucher tidak valid atau sudah kadaluarsa';
message.style.color = '#dc2626';
updatePrice();
}
message.style.display = 'block';
})
.catch(() => {
currentDiscount = 0;
message.textContent = 'Voucher tidak valid atau sudah kadaluarsa';
message.style.color = '#dc2626';
message.style.display = 'block';
updatePrice();
});
}

document.getElementById('buyForm').addEventListener('submit', function() {
document.getElementById('voucherHidden').value = document.getElementById('voucherInput').value;
document.getElementById('paymentMethodInput').value = selectedPayment;
});
</script>