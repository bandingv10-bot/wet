  <!-- HEADER -->
  <header>
    <nav>
      <div class="logo">✨ WET</div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <!-- SERVICES SECTION -->
  <section class="services">
    <h2 class="section-title">Our <span>Services</span></h2>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-number">01</div>
        <h3>Web Design</h3>
        <p>Beautiful, modern web designs that captivate your audience and convert visitors into customers. We create stunning visual experiences that reflect your brand.</p>
      </div>
      <div class="service-card">
        <div class="service-number">02</div>
        <h3>Web Development</h3>
        <p>Robust, scalable web applications built with the latest technologies. From frontend to backend, we create solutions that perform flawlessly.</p>
      </div>
      <div class="service-card">
        <div class="service-number">03</div>
        <h3>Mobile Apps</h3>
        <p>Native and cross-platform mobile applications that users love. Optimized for performance and user experience on all devices.</p>
      </div>
      <div class="service-card">
        <div class="service-number">04</div>
        <h3>UI/UX Design</h3>
        <p>User-centered design approach that creates intuitive interfaces and delightful interactions. Every pixel serves a purpose.</p>
      </div>
      <div class="service-card">
        <div class="service-number">05</div>
        <h3>Consulting</h3>
        <p>Strategic guidance to help you navigate digital transformation. We provide expert advice on technology, design, and business strategy.</p>
      </div>
      <div class="service-card">
        <div class="service-number">06</div>
        <h3>Maintenance & Support</h3>
        <p>Ongoing support and maintenance to keep your digital assets running smoothly. Security updates, performance optimization, and feature enhancements.</p>
      </div>
    </div>
  </section>

  <!-- PROCESS SECTION -->
  <section class="process mt-4">
    <h2>Our <span style="color: #667eea;">Process</span></h2>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">01</div>
        <h4>Discovery</h4>
        <p>Understanding your goals, audience, and requirements</p>
      </div>
      <div class="process-step">
        <div class="step-number">02</div>
        <h4>Strategy</h4>
        <p>Planning the approach and defining success metrics</p>
      </div>
      <div class="process-step">
        <div class="step-number">03</div>
        <h4>Design</h4>
        <p>Creating beautiful mockups and user experiences</p>
      </div>
      <div class="process-step">
        <div class="step-number">04</div>
        <h4>Development</h4>
        <p>Building robust, scalable solutions</p>
      </div>
      <div class="process-step">
        <div class="step-number">05</div>
        <h4>Testing</h4>
        <p>Thorough quality assurance and optimization</p>
      </div>
      <div class="process-step">
        <div class="step-number">06</div>
        <h4>Launch</h4>
        <p>Deployment and ongoing support</p>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="hero mb-4">
    <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Ready to get started?</h2>
    <p>Let's bring your vision to life with our services</p>
